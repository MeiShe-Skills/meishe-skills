{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meishe ShortVideo route capability catalog",
  "type": "object",
  "required": [
    "schemaVersion", "track", "configurationSource", "verifiedVersions",
    "fieldMappings", "valueMappings", "capabilities"
  ],
  "properties": {
    "schemaVersion": {"const": 2},
    "track": {"const": "native-ios"},
    "configurationSource": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "verifiedVersions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "fieldMappings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/bilingualMapping"}
    },
    "valueMappings": {
      "type": "object",
      "propertyNames": {"pattern": "^.+::.+$"},
      "additionalProperties": {"$ref": "#/$defs/bilingualMapping"}
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id", "members", "aliases", "type", "default", "constraints", "enumValues",
          "dependencies", "conflicts", "mutationTarget", "platforms", "alternative", "verification"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9.-]+$"},
          "members": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "aliases": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "type": {"type": "string", "minLength": 1},
          "default": {},
          "constraints": {"type": "array", "items": {"type": "string"}},
          "enumValues": {"type": "array"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "conflicts": {"type": "array", "items": {"type": "string"}},
          "mutationTarget": {"type": "string", "minLength": 1},
          "platforms": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {"const": "ios"},
            "additionalProperties": {
              "type": "object",
              "required": ["version", "status", "evidence", "behavior"],
              "properties": {
                "version": {"type": "string"},
                "status": {
                  "enum": [
                    "verified", "boundary_verified", "partial", "ineffective", "limited",
                    "unsupported", "transport_verified", "unverified"
                  ]
                },
                "evidence": {
                  "enum": [
                    "device-behavior", "media-output", "bridge-payload", "serialization",
                    "static-api", "external-required"
                  ]
                },
                "behavior": {"type": "string", "minLength": 1}
              }
            }
          },
          "alternative": {"type": "string"},
          "verification": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "bilingualMapping": {
      "type": "object",
      "required": ["zh", "aliases"],
      "properties": {
        "zh": {"type": "string", "minLength": 1},
        "aliases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
